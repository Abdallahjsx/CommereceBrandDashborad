# Dependencies — installed fresh inside the container
node_modules

# Next.js build output — rebuilt inside the container
.next
out

# Version control
.git
.gitignore

# Environment files — inject via Docker --env-file or secrets
.env
.env.*

# IDE / editor config
.vscode
.idea
*.swp
*.swo

# OS artifacts
.DS_Store
Thumbs.db

# Debug & log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Docker files themselves (prevent recursive context)
Dockerfile
docker-compose*.yml
.dockerignore

# Misc
README.md
LICENSE
*.md
coverage
.vercel
*.tsbuildinfo
